# =============================================================================
# Hecatrace — Workspace configuration template
# =============================================================================
# Copy this file to .hecatrace.env and adjust the values:
#   cp .hecatrace.env.example .hecatrace.env
#
# This file is loaded automatically by the 'hecatrace' wrapper
# AND by 'docker compose' (via env_file in docker-compose.yml).
#
# One configuration per case / investigation directory.
# Do not version this file if the paths contain sensitive
# information about the cases being handled.
# =============================================================================

# Docker image to use
HECATRACE_IMAGE=hecatrace:latest

# Path to the digital evidence on the host.
# This directory will be mounted at /evidences (read-only) in the container.
# Can be an NFS mount point, a local directory, etc.
HECATRACE_EVIDENCE=/srv/evidences/case_XXX

# Output directory on the host.
# Will be mounted at /output (read/write) in the container.
# Results, CSVs, timelines and report.json will be written here.
HECATRACE_OUTPUT=/srv/results/case_XXX

# Execution logs directory on the host.
# Will be mounted at /logs (read/write) in the container.
HECATRACE_LOGS=/srv/logs
